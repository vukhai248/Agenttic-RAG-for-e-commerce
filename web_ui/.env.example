# Cấu hình biến môi trường cho dự án Agentic RAG Web TMĐT

# 1. Supabase Config (Lấy từ project settings -> API của Supabase Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 2. Stripe Config (Lấy từ Stripe Dashboard -> Developers -> API Keys ở Test Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# 3. RAG Service URL (Mặc định trỏ đến API Route Mock nội bộ của Next.js, sau này đổi sang service Python FastAPI thật)
NEXT_PUBLIC_RAG_SERVICE_URL=http://localhost:3000/api/chat
